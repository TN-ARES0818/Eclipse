<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_nav"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:orientation="horizontal"
    android:background="@drawable/nav_background_drawable"
    android:gravity="center_vertical">

    <!-- Back Button -->
    <ImageView
        android:id="@+id/nav_back"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_back"
        android:padding="18dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back" />

    <!-- Forward Button -->
    <ImageView
        android:id="@+id/nav_forward"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_forward"
        android:padding="18dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/forward" />

    <!-- Home (Eclipse) Button -->
    <ImageView
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_home_eclipse"
        android:padding="12dp"
        android:background="@drawable/home_button_background"
        android:contentDescription="@string/home" />

    <!-- Tabs Button -->
    <FrameLayout
        android:id="@+id/nav_tabs"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?android:attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/nav_tabs_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_tabs"
            android:padding="18dp"
            android:contentDescription="@string/tabs" />
        <TextView
            android:id="@+id/nav_tabs_badge"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="top|end"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/badge_background"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="8sp"
            android:visibility="gone"
            android:text="1" />
    </FrameLayout>

    <!-- Menu Button -->
    <ImageView
        android:id="@+id/nav_menu"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_menu"
        android:padding="18dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/menu" />

</LinearLayout>
